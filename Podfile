#use_frameworks!
platform :ios, '9.0'
def blaze_frameworks
    #JSON Mapper to object
    pod 'JSONModel', '~> 1.8'
    #Networking Library Dependencies
    pod 'AFNetworking', '~> 3.0'
    #ActionPicker
    pod 'ActionSheetPicker-3.0'

end

target 'blaze' do
    use_frameworks!
    blaze_frameworks
end

